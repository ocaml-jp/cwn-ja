(executable
 (name cwn_ja)
 (public_name cwn_ja)
 (libraries
  async
  core
  core_unix.command_unix
  cwn_ja_lib)
 (preprocess
  (pps ppx_jane)))

; Snapshot of every subcommand + flag, regenerated on every build. Promoted
; back into the source tree so `bin/help.txt` is browsable on GitHub and
; reviewable as part of any CLI change.
(rule
 (target help.txt)
 (mode promote)
 (action
  (with-stdout-to
   %{target}
   (run %{exe:cwn_ja.exe} help -recursive -flags))))
