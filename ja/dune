(include dune.inc)

; Regenerates dune.inc whenever the set of *.xml inputs changes. The mode is
; promote so the regenerated file lands back in the source tree; commit it.
(rule
 (deps (glob_files *.xml))
 (target dune.inc)
 (mode promote)
 (action
  (with-stdout-to %{target}
   (run %{exe:../bin/gen_dune_inc.exe}))))
